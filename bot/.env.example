# Phase 1 — LOCAL DEV ONLY. Use a dedicated TEST bot, not the production one.
# Secrets live in Key Vault kv-bronxtc-dev under namespace launch11--dev--* (NOT --production--*).
# Never write production credentials into this file (council finding S1).

# Telegram bot token of a THROWAWAY test bot from @BotFather
LAUNCH11_BOT_TOKEN=123456:test-bot-token

# Anthropic API key (dev key, low spend cap)
ANTHROPIC_API_KEY=sk-ant-dev-...

# Model for the pipeline brain
LAUNCH11_MODEL=claude-sonnet-5

# Postgres
DATABASE_URL=postgresql://launch11:launch11@localhost:5432/launch11

# Rollout kill-switch: comma-separated Telegram user IDs allowed during beta.
# Empty => public (billing is the only gate). Keep populated while smoke-testing.
# Real ids come from Key Vault (launch11--<env>--BETA-ALLOWLIST-IDS) via deploy/fetch-env.sh.
BETA_ALLOWLIST_IDS=123456789

# Owners: unlimited runs, never billed, never beta-gated. Comma-separated Telegram IDs.
# Real ids come from Key Vault (launch11--<env>--OWNER-IDS) — never commit them.
OWNER_IDS=123456789

# Optional
SENTRY_DSN=
MAX_CONTEXT_MESSAGES=40
MAX_ARTIFACT_BYTES=20000
MAX_SESSION_ARTIFACT_BYTES=200000
